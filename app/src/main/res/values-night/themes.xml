<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Triggerly" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/flow_blue</item>
        <item name="colorPrimaryVariant">@color/app_background</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/cyan_accent</item>
        <item name="colorSecondaryVariant">@color/flow_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Dialog and Picker styles -->
        <item name="alertDialogTheme">@style/Theme.Triggerly.Dialog</item>
        <item name="android:timePickerStyle">@style/Theme.Triggerly.TimePicker</item>
    </style>

    <style name="Theme.Triggerly.Dialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/flow_blue</item>
        <item name="colorAccent">@color/flow_blue</item>
        <item name="android:windowBackground">@color/card_surface</item>
    </style>

    <style name="Theme.Triggerly.TimePicker" parent="Widget.MaterialComponents.TimePicker">
        <item name="colorPrimary">@color/flow_blue</item>
        <item name="colorAccent">@color/flow_blue</item>
    </style>
</resources>